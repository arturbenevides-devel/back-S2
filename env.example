DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_EXPIRES_IN="24h"
PORT=3000
NODE_ENV=development
TZ=America/Sao_Paulo

# CORS (origens permitidas, separadas por vírgula; padrão: localhost:5173 e 3000)
# CORS_ORIGIN="http://localhost:5173,http://localhost:3000"

# Email Configuration
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER="seu-email@gmail.com"
EMAIL_PASS="sua-senha-de-app"
EMAIL_FROM="Agente Mais"
FRONTEND_URL="https://agente-mais.develcode.com.br"

# Whats2 — envio/recebimento (uma instância; credenciais da API Whats2 documentada em Whats2-documentation)
WHATS2_API_URL="https://whats2.dextino.com.br/api"
WHATS2_EMAIL=""
WHATS2_PASSWORD=""
WHATS2_INSTANCE_ID=""
# CNPJ do tenant (14 dígitos) cujo schema receberá mensagens do webhook — obrigatório para processar POST /webhooks/whats2
WHATS2_WEBHOOK_TENANT_CNPJ=""
# Segredo opcional: mesmo valor em ?token= na URL do webhook registrado na Whats2
WHATS2_WEBHOOK_SECRET=""
# Base pública HTTPS da API (ngrok/Azure), usada para PUT /instances/{id}/webhook na Whats2
WEBHOOK_PUBLIC_BASE_URL=""
# true = registra webhook no startup (requer WEBHOOK_PUBLIC_BASE_URL e credenciais válidas)
WHATS2_AUTO_REGISTER_WEBHOOK="false"
# Opcional: caminho customizado na API Whats2 para POST verificar se o número tem WhatsApp (ex.: /instances/{instanceId}/contacts/check)
# WHATS2_CHECK_EXISTS_PATH=""
